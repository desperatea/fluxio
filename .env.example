# C5Game (старое API, для справки)
C5GAME_APP_KEY=your_app_key_here
C5GAME_APP_SECRET=your_app_secret_here

# CS2DT (HaloSkins — основная платформа покупок)
CS2DT_APP_KEY=your_cs2dt_app_key
CS2DT_APP_SECRET=your_cs2dt_app_secret
CS2DT_TRADE_URL=https://steamcommunity.com/tradeoffer/new/?partner=...&token=...

# Steam
STEAM_API_KEY=your_steam_api_key
TRADE_URL=https://steamcommunity.com/tradeoffer/new/?partner=...&token=...
STEAM_LOGIN_SECURE=your_steam_login_secure_cookie
SESSION_ID=your_session_id
BROUSER_ID=your_browser_id

# Telegram
TELEGRAM_BOT_TOKEN=your_token
TELEGRAM_CHAT_ID=your_chat_id

# PostgreSQL
POSTGRES_USER=bot
POSTGRES_PASSWORD=secret
POSTGRES_DB=c5game_bot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Прокси (опционально, формат: host:port:user:pass)
HTTP_PROXY=
HTTPS_PROXY=

# Логирование
LOG_LEVEL=INFO
