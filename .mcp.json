{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://bot:secret@localhost:5433/c5game_bot"
      ]
    },
    "redis": {
      "command": "npx",
      "args": ["-y", "mcp-server-redis", "--url", "redis://localhost:6379"]
    }
  }
}
